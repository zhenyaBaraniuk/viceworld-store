{
    "compilerOptions": {
        "target": "ES2020",
        "lib": ["ES2020", "DOM", "DOM.Iterable"],
        "module": "ESNext",
        "moduleResolution": "bundler",
        "jsx": "react-jsx",
        "strict": true,
        "noEmit": true,
        "skipLibCheck": true,
        "isolatedModules": true,
        "resolveJsonModule": true,
        "types": ["node", "vite/client"],
        "baseUrl": ".",
        "paths": {
            "@/*": ["resources/js/*"],
            "@css/*": ["resources/css/*"],
        }
    },
    "include": ["resources/js/**/*"],
    "exclude": ["node_modules", "public"]
}
